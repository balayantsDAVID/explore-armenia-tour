# ============================================================
# ExploreArmenia — Переменные окружения
# ============================================================
# ВАЖНО: Этот файл — ШАБЛОН. Не храни здесь реальные данные.
# На Render.com эти значения вводятся в разделе "Environment"
# ============================================================

# --- MySQL на Бегете ---
# Найди в панели Бегет → Базы данных → MySQL
DB_HOST=mysql.beget.com          # хост (уточни в панели Бегета)
DB_PORT=3306                     # порт MySQL (всегда 3306)
DB_NAME=your_db_name             # имя базы данных
DB_USER=your_db_user             # пользователь базы
DB_PASSWORD=your_db_password     # пароль

# --- Google Gemini API ---
# Получи на aistudio.google.com → Get API Key
GEMINI_API_KEY=AIzaSy...

# --- Настройки приложения ---
# Эти URL появятся после деплоя на Render
RENDER_URL=https://explore-armenia.onrender.com

# --- Cloudflare R2 (для фото) ---
# Заполним позже когда дойдём до этапа с фото
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=explore-armenia-photos
R2_PUBLIC_URL=
