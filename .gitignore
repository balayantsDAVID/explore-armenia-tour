# ============================================================
# .gitignore — файлы которые НЕ заливаются на GitHub
# ============================================================

# Реальные секреты — НИКОГДА не заливать
.env
*.env
!.env.example

# Python кэш
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.py[cod]

# Виртуальное окружение Python
venv/
env/
.venv/

# Node.js зависимости (устанавливаются на Render автоматически)
node_modules/

# Временные файлы генерации
/tmp/
*.tmp
tour_*.docx
tour_*.pdf

# macOS мусор
.DS_Store
.AppleDouble

# IDE файлы
.idea/
.vscode/
*.swp
*.swo

# Логи
*.log